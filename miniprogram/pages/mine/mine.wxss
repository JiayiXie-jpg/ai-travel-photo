.page-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: #e0e0e0;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-card {
  display: flex;
  align-items: center;
  background: #1e1e1e;
  border-radius: 16rpx;
  padding: 20rpx;
}

.task-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.task-info {
  flex: 1;
  margin: 0 20rpx;
}

.task-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #e0e0e0;
}

.task-time {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-top: 6rpx;
}

.task-status {
  display: inline-block;
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

.status-completed { background: #1a3a2a; color: #4ade80; }
.status-failed { background: #3d1c1c; color: #f87171; }
.status-processing, .status-submitted { background: #1c2d4a; color: #60a5fa; }
.status-pending { background: #3d3520; color: #fbbf24; }

.task-result-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.task-arrow {
  color: #555;
  font-size: 32rpx;
  flex-shrink: 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #888;
  margin: 20rpx 0;
}

.empty-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-decoration: none;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #888;
}
