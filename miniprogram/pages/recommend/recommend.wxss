.header {
  text-align: center;
  padding: 32rpx 0 24rpx;
}

.header-icon {
  font-size: 56rpx;
  display: block;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #f093fb;
  margin-top: 8rpx;
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

/* 上传区域 */
.upload-area {
  width: 100%;
  height: 400rpx;
  border: 2rpx dashed #444;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1e1e1e;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.upload-area.has-photo {
  border: none;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-plus {
  font-size: 72rpx;
  color: #f093fb;
}

.upload-hint {
  font-size: 24rpx;
  color: #888;
  margin-top: 12rpx;
}

.upload-preview {
  width: 100%;
  height: 400rpx;
}

/* 按钮 */
.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.submit-btn.disabled {
  opacity: 0.5;
}

.retry-btn {
  margin-top: 24rpx;
  background: #1e1e1e;
  color: #f093fb;
  border: 2rpx solid #f093fb;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-pulse {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(240, 147, 251, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: pulse 1.5s ease-in-out infinite;
}

.loading-pulse-inner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.3); opacity: 0.6; }
}

.loading-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e0e0e0;
  margin-top: 40rpx;
}

.loading-hint {
  font-size: 24rpx;
  color: #888;
  margin-top: 12rpx;
}

/* 分析卡片 */
.analysis-card {
  background: linear-gradient(135deg, #1e1e3e 0%, #2a1e3e 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
}

.analysis-title {
  display: block;
  font-size: 28rpx;
  color: #f093fb;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.analysis-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.analysis-tag {
  background: rgba(255,255,255,0.1);
  color: #e0e0e0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.analysis-tag.highlight {
  background: rgba(240,147,251,0.15);
  color: #f093fb;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #e0e0e0;
  margin-bottom: 20rpx;
}

/* 推荐卡片 */
.rec-card {
  background: #1e1e1e;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.rec-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.rec-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #e0e0e0;
}

.rec-score {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.rec-reason {
  font-size: 24rpx;
  color: #aaa;
  line-height: 1.6;
}
