.processing-state, .fail-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.pulse-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(102, 126, 234, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: pulse 1.5s ease-in-out infinite;
}

.pulse-dot {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.3); opacity: 0.6; }
}

.processing-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 40rpx;
  color: #e0e0e0;
}

.processing-hint {
  font-size: 26rpx;
  color: #888;
  margin-top: 12rpx;
}

.result-state {
  padding-bottom: 40rpx;
}

.result-card {
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
}

.result-img {
  width: 100%;
  display: block;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: 2rpx solid #667eea;
  color: #667eea;
  background: #1e1e1e;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
}

.fail-icon {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  border-radius: 50%;
  background: #3d1c1c;
  color: #ef4444;
  font-size: 56rpx;
  font-weight: bold;
}

.fail-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 30rpx;
  color: #e0e0e0;
}

.fail-message {
  font-size: 26rpx;
  color: #888;
  margin: 12rpx 0 40rpx;
}
